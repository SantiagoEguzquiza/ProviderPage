---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBanner from '../components/TrustBanner.astro';
import FeatureBento from '../components/react/FeatureBento.tsx';
import RoleTabs from '../components/react/RoleTabs.tsx';
import TechSection from '../components/TechSection.astro';
import Roadmap from '../components/Roadmap.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />
	<main
		id="page-scroll-root"
		class="page-snap-container relative h-[100dvh] w-full snap-y snap-mandatory overflow-y-auto overflow-x-hidden scroll-pt-16 scroll-auto bg-[#F8FAFC] transition-theme-colors dark:bg-[#262D33]"
	>
		<section
			id="inicio"
			class="section-snap-panel flex min-h-[100dvh] snap-start snap-always flex-col justify-between bg-[#F8FAFC] transition-theme-colors dark:bg-[#262D33]"
			aria-label="Inicio y confianza"
		>
			<div class="flex min-h-0 flex-1 flex-col justify-center">
				<Hero />
			</div>
			<TrustBanner />
		</section>

		<FeatureBento client:visible />

		<section
			class="section-snap-panel flex min-h-[100dvh] snap-start snap-always flex-col bg-white transition-theme-colors dark:bg-[#262D33]"
			aria-label="Ciclo comercial y tecnología"
		>
			<TechSection />
			<RoleTabs client:visible />
		</section>

		<Roadmap />

		<section
			class="section-snap-panel flex min-h-[100dvh] snap-start snap-always flex-col justify-between bg-[#f8fafc] transition-theme-colors dark:bg-[#262D33]"
			aria-label="Contacto y pie de página"
		>
			<div class="flex min-h-0 flex-1 flex-col justify-center px-0 py-6 sm:py-8">
				<CtaSection />
			</div>
			<Footer />
		</section>
	</main>
</Layout>
