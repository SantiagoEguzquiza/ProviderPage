---
import { techSection } from '../data/site';
---

<section
	id={techSection.id}
	class="shrink-0 min-h-0 bg-white px-0 py-10 transition-theme-colors sm:py-12 dark:bg-[#262D33]"
	aria-labelledby="tech-heading"
>
	<div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8" data-scroll-reveal>
		<h2
			id="tech-heading"
			class="text-gradient-section text-2xl font-semibold tracking-tighter leading-tight text-balance sm:text-3xl"
		>
			{techSection.title}
		</h2>
		<p class="mt-4 text-lg leading-relaxed text-[#64748b] transition-theme-colors dark:text-[#94a3b8]">
			{techSection.body}
		</p>
	</div>
</section>
