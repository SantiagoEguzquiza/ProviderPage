---
import { footer, site } from '../data/site';
---

<footer class="border-t border-[#e5e7eb] bg-white py-14" id="footer">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
			<div>
				<p class="text-lg font-semibold text-[#111827]">{site.name}</p>
				<p class="mt-3 max-w-xs text-sm leading-relaxed text-[#6b7280]">{footer.tagline}</p>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-[#9ca3af]">{footer.columns.producto.title}</p>
				<ul class="mt-4 space-y-3">
					{
						footer.columns.producto.links.map((link) => (
							<li>
								<a href={link.href} class="text-sm font-medium text-[#4b5563] transition hover:text-[#111827]">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-[#9ca3af]">{footer.columns.empresa.title}</p>
				<ul class="mt-4 space-y-3">
					{
						footer.columns.empresa.links.map((link) => (
							<li>
								<a href={link.href} class="text-sm font-medium text-[#4b5563] transition hover:text-[#111827]">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<p class="mt-12 border-t border-[#e5e7eb] pt-8 text-center text-xs text-[#9ca3af]">
			{footer.legal}
		</p>
	</div>
</footer>
