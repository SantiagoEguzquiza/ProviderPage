---
import { footer, site } from '../data/site';
---

<footer
	class="min-h-0 border-t border-white/10 bg-[#262d33] py-14 text-slate-200"
	id="footer"
	data-scroll-reveal
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
			<div>
				<p class="text-lg font-semibold text-white">{site.name}</p>
				<p class="mt-3 max-w-xs text-sm leading-relaxed text-slate-400">{footer.tagline}</p>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-slate-500">{footer.columns.producto.title}</p>
				<ul class="mt-4 space-y-3">
					{
						footer.columns.producto.links.map((link) => (
							<li>
								<a href={link.href} class="text-sm font-medium text-slate-400 transition hover:text-[#1cb5ac]">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-slate-500">{footer.columns.empresa.title}</p>
				<ul class="mt-4 space-y-3">
					{
						footer.columns.empresa.links.map((link) => (
							<li>
								<a href={link.href} class="text-sm font-medium text-slate-400 transition hover:text-[#1cb5ac]">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<p class="mt-12 border-t border-white/10 pt-8 text-center text-xs text-slate-500">
			{footer.legal}
		</p>
	</div>
</footer>
