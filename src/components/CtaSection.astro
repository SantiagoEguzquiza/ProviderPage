---
import { finalCta } from '../data/site';
---

<div
	id="cta"
	role="region"
	class="relative min-h-0 overflow-hidden border-0 bg-transparent py-8 sm:py-10"
	aria-labelledby="cta-heading"
>
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<div
			class="absolute -left-[10%] top-1/4 h-[min(80vw,560px)] w-[min(80vw,560px)] rounded-full bg-[#1cb5ac]/14 blur-[100px]"
		/>
		<div
			class="absolute -right-[5%] bottom-[10%] h-[min(70vw,480px)] w-[min(70vw,480px)] rounded-full bg-[#154d6c]/12 blur-[90px]"
		/>
		<div
			class="absolute left-1/3 top-0 h-[min(50vw,360px)] w-[min(50vw,360px)] rounded-full bg-[#1cb5ac]/10 blur-[80px]"
		/>
	</div>

	<div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8" data-scroll-reveal>
		<div
			class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-[#262d33] via-[#1e293b] to-[#154d6c] px-8 py-14 text-center shadow-[0_32px_80px_-16px_rgb(38_45_51/0.45)] sm:px-12"
		>
			<div class="pointer-events-none absolute -right-20 -top-20 size-64 rounded-full bg-[#1cb5ac]/15 blur-3xl" aria-hidden="true" />
			<div class="pointer-events-none absolute -bottom-24 -left-16 size-56 rounded-full bg-[#154d6c]/40 blur-3xl" aria-hidden="true" />
			<div
				class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_60%_at_50%_0%,rgb(28_181_172/0.12),transparent)]"
				aria-hidden="true"
			/>

			<h2
				id="cta-heading"
				class="relative text-3xl font-semibold tracking-tighter leading-tight text-balance text-white sm:text-4xl"
			>
				{finalCta.title}
			</h2>
			<p class="relative mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-white/85">
				{finalCta.text}
			</p>
			<div class="relative mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
				<a
					href="mailto:hola@provider.app"
					class="btn-primary-glow inline-flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-[#154d6c] to-[#1cb5ac] px-8 py-3.5 text-sm font-semibold text-white shadow-sm transition duration-300 hover:brightness-[1.05] sm:w-auto"
				>
					{finalCta.primary}
				</a>
				<a
					href="mailto:dev@provider.app"
					class="inline-flex w-full items-center justify-center rounded-xl border border-white/25 bg-white/10 px-8 py-3.5 text-sm font-semibold text-white shadow-sm backdrop-blur-md transition duration-300 hover:border-white/40 hover:bg-white/15 hover:shadow-[0_0_40px_-8px_rgb(255_255_255/0.25)] sm:w-auto"
				>
					{finalCta.secondary}
				</a>
			</div>
		</div>
	</div>
</div>
