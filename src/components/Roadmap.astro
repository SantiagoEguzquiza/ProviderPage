---
import { roadmap } from '../data/site';
---

<section
	id={roadmap.id}
	class="section-snap-panel flex min-h-[100dvh] flex-col border-t border-[#154d6c]/10 bg-[#f8fafc] py-20 transition-theme-colors sm:py-24 dark:border-[#f8fafc]/10 dark:bg-[#2a3239]"
	aria-labelledby="roadmap-heading"
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8" data-scroll-reveal>
		<div class="mx-auto max-w-2xl text-center">
			<h2
				id="roadmap-heading"
				class="text-gradient-section text-3xl font-semibold tracking-tighter leading-tight text-balance sm:text-4xl"
			>
				{roadmap.title}
			</h2>
			<p class="mt-4 text-lg leading-relaxed text-[#64748b] transition-theme-colors dark:text-[#94a3b8]">
				{roadmap.subtitle}
			</p>
		</div>

		<ol
			class="relative mx-auto mt-14 max-w-2xl border-l border-[#154d6c]/20 pl-8 transition-theme-colors dark:border-[#f8fafc]/20"
		>
			{
				roadmap.items.map((item, i) => (
					<li class="relative pb-10 last:pb-0">
						<span
							class="absolute -left-[39px] flex size-5 items-center justify-center rounded-full border-2 border-[#1cb5ac] bg-white shadow-sm transition-theme-colors dark:bg-[#262d33]"
							aria-hidden="true"
						>
							<span class="size-2 rounded-full bg-[#1cb5ac]" />
						</span>
						<p class="text-base font-medium leading-relaxed text-[#154d6c] transition-theme-colors dark:text-[#f8fafc]">
							{item}
						</p>
					</li>
				))
			}
		</ol>
	</div>
</section>
